22, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":5,"id":"bc17da53-d52b-4c18-8b4b-6048ca68f5e8","page_size":[595,842],"block_position":"5-8"},{"bbox":[57,692,503,757],"index":9,"angle":0,"type":"image","img_path":"/b76888dcb1fc04fdb35051ffb326c47c82fe1db116b08b4eb5cd8f00b1b00cfe.jpg","color":{"line":"rgba(89, 92, 220, 1)","fill":"rgba(89, 92, 220, 1)"},"img_ratio":0.7495798319327731,"page_idx":5,"id":"490f5b07-ee74-4156-af91-4063548552eb","page_size":[595,842],"block_position":"5-9"},{"bbox":[45,760,233,775],"type":"text","angle":0,"index":10,"text":".点击取消变为训练代码四个字即可","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":5,"id":"b847b7a2-8eee-4a41-96b5-112208ab8969","page_size":[595,842],"block_position":"5-10"},{"bbox":[64,777,476,839],"index":11,"angle":0,"type":"image","img_path":"/1570dadb890d8c8f11ea7c14e9fce3f8b98ebd222278fe336bd9e42c43e90731.jpg","color":{"line":"rgba(89, 92, 220, 1)","fill":"rgba(89, 92, 220, 1)"},"img_ratio":0.692436974789916,"page_idx":5,"id":"6e757e08-42ea-4b9c-8cfc-16e241d2c33d","page_size":[595,842],"block_position":"5-11"}],[{"bbox":[23,20,250,37],"type":"text","angle":0,"index":0,"text":".直接点击快速设置界面的调谐按钮：","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":6,"id":"c8b10ac8-5b95-4b3d-9dba-101b4b1c0881","page_size":[595,842],"block_position":"6-0"},{"bbox":[262,0,575,263],"index":1,"angle":0,"type":"image","img_path":"/a39071873c410e20f50154813aa90ae013e9d9ff581e9fa43771c782f59ed151.jpg","color":{"line":"rgba(89, 92, 220, 1)","fill":"rgba(89, 92, 220, 1)"},"img_ratio":0.5260504201680672,"page_idx":6,"id":"3c7713b0-d51b-4d54-a5b5-885a25e3a650","page_size":[595,842],"block_position":"6-1"},{"bbox":[10,327,230,367],"type":"text","angle":0,"index":2,"text":".调谐完成后如果出现多个结果，选择认为不错的配置点击-应用选定的-完成参数修改","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":6,"id":"2be5700b-e97e-4978-8acc-79cfd1a791dd","page_size":[595,842],"block_position":"6-2"},{"bbox":[249,271,590,499],"index":3,"angle":0,"type":"image","img_path":"/f460e3746de36c7f6d1fb42436fcaa1142f78f190288e2b927de65b721ff01a7.jpg","color":{"line":"rgba(89, 92, 220, 1)","fill":"rgba(89, 92, 220, 1)"},"img_ratio":0.573109243697479,"page_idx":6,"id":"f7a3dec8-ccd3-4f27-9ad4-09bd1fe68e88","page_size":[595,842],"block_position":"6-3"},{"bbox":[8,489,163,508],"type":"title","angle":0,"index":4,"text":"# 4.2.手动配置调试部分","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":6,"id":"9fbce084-ec3b-4c32-9b12-ea0cbe809b72","page_size":[595,842],"block_position":"6-4"},{"bbox":[8,518,534,821],"index":5,"angle":0,"type":"image","img_path":"/ce50c79da9ccdbe9968bf1ef427fbc2007bda47a5ba5d1138dfc4db1b3fb9885.jpg","color":{"line":"rgba(89, 92, 220, 1)","fill":"rgba(89, 92, 220, 1)"},"img_ratio":0.8840336134453781,"page_idx":6,"id":"a5993539-0883-44ef-88f6-1319bea9d364","page_size":[595,842],"block_position":"6-5"}],[{"bbox":[1,17,155,45],"type":"text","angle":0,"index":0,"text":".点击触发器如果图像焦距模糊","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":7,"id":"a4a39090-7300-4673-ad58-73697f17dc4f","page_size":[595,842],"block_position":"7-0"},{"bbox":[11,56,148,84],"type":"text","angle":0,"index":1,"text":"点击-操作-优化焦点-进行自动对焦","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":7,"id":"f810790f-adb7-4961-ae44-3380b7257e26","page_size":[595,842],"block_position":"7-1"},{"bbox":[5,100,148,147],"type":"text","angle":0,"index":2,"text":"优化焦点 OK后适当调整光源，曝光，增益。然后触发解码，","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":7,"id":"6c325775-316d-44e5-982b-12cbf8d2010c","page_size":[595,842],"block_position":"7-2"},{"bbox":[26,149,127,188],"type":"text","angle":0,"index":3,"text":"光源有四个点光上面两个为篇振光下面两个为高亮光","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":7,"id":"6a129971-a7d8-441d-822f-a85b09220f7a","page_size":[595,842],"block_position":"7-3"},{"bbox":[22,191,157,321],"index":4,"angle":0,"type":"image","img_path":"/3f9d1b688ba2efc6742d646ee02a05af76e7e307403db766d79f038c4c7fcc19.jpg","color":{"line":"rgba(89, 92, 220, 1)","fill":"rgba(89, 92, 220, 1)"},"img_ratio":0.226890756302521,"page_idx":7,"id":"1a36fce6-aaa1-4219-894f-41bd2e58ebe9","page_size":[595,842],"block_position":"7-4"},{"bbox":[22,323,150,386],"type":"text","angle":0,"index":5,"text":"鼠标点击四个光源任意个，点击位置变红即此位置光源并后，之吴闭，四个光源可随意奔九个","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":7,"id":"1ab27b4f-f796-45d2-939b-0070c06abfae","page_size":[595,842],"block_position":"7-5"},{"bbox":[20,395,149,435],"type":"text","angle":0,"index":6,"text":"触发图像对比度清晰解码时间短且稳定，说明配置调试OK","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":7,"id":"23c42f39-574b-40a6-aec4-a86167046dcb","page_size":[595,842],"block_position":"7-6"},{"bbox":[7,442,160,482],"type":"text","angle":0,"index":7,"text":".调试OK后需其它setup焦点范围数值改为和当前调试的setup焦点一致如图都改为86","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":7,"id":"f89a5eeb-2a8d-4b3c-b035-f000398944e2","page_size":[595,842],"block_position":"7-7"},{"bbox":[9,500,141,517],"type":"text","angle":0,"index":8,"text":"将需要的setup打勾后用","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":7,"id":"48c22034-fc7f-4257-9983-a01c72a11ddf","page_size":[595,842],"block_position":"7-8"},{"bbox":[18,603,114,619],"type":"text","angle":0,"index":9,"text":"完成后-保存设置","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":7,"id":"6b1d07d0-b631-43ba-bc81-9b24389f9034","page_size":[595,842],"block_position":"7-9"},{"bbox":[161,2,586,82],"index":10,"angle":0,"type":"image","img_path":"/3a8ef9f0d0b9851f3926029dddbaeef4e2fe34b3a15b5cfdab8ccad730960faf.jpg","color":{"line":"rgba(89, 92, 220, 1)","fill":"rgba(89, 92, 220, 1)"},"img_ratio":0.7142857142857143,"page_idx":7,"id":"919b2581-998d-4406-9c55-d2a696abee6c","page_size":[595,842],"block_position":"7-10"},{"bbox":[170,99,586,488],"index":11,"angle":0,"type":"image","img_path":"/b9da04ae461f1f0c25809be97a4afc03ee4e62588f199e03fb13e55367c69870.jpg","color":{"line":"rgba(89, 92, 220, 1)","fill":"rgba(89, 92, 220, 1)"},"img_ratio":0.6991596638655462,"page_idx":7,"id":"e238a436-1aa2-403b-9e6d-dfa446b5417b","page_size":[595,842],"block_position":"7-11"},{"bbox":[205,572,550,663],"index":12,"angle":0,"type":"image","img_path":"/df86c47019025f4aa5fd8873d6c805820f3efa84af09e418c67e45fa78b5cad8.jpg","color":{"line":"rgba(89, 92, 220, 1)","fill":"rgba(89, 92, 220, 1)"},"img_ratio":0.5798319327731093,"page_idx":7,"id":"6342bcdf-4238-4e26-9385-9660b368f057","page_size":[595,842],"block_position":"7-12"},{"bbox":[168,717,539,735],"type":"text","angle":0,"index":13,"text":"注意：调试配置时当有多个配置时只勾选一个配置进行调试","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":7,"id":"c75fc26c-c78f-4114-9d29-742c00b824bd","page_size":[595,842],"block_position":"7-13"}],[{"bbox":[19,10,176,29],"type":"title","angle":0,"index":0,"text":"# 4.3.如何添","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":8,"id":"b71ee5b8-810c-4eb4-8b67-5da4e8dfc37f","page_size":[595,842],"block_position":"8-0"},{"bbox":[88,0,570,442],"index":1,"angle":0,"type":"image","img_path":"/f83017a05d20e30f6155dc83ba07991cca8fcc0268c5fb34560fdb7241ee4717.jpg","color":{"line":"rgba(89, 92, 220, 1)","fill":"rgba(89, 92, 220, 1)"},"img_ratio":0.8100840336134454,"page_idx":8,"id":"fa4e2a98-4ee7-4c72-95b1-1abb66fb41b6","page_size":[595,842],"block_position":"8-1"},{"bbox":[18,454,316,471],"type":"title","angle":0,"index":2,"text":"# 4.4.如何查看码制是否被训练及如何解除码制训","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":8,"id":"feca1096-d05a-4dbe-8b31-67b7fafc5fcc","page_size":[595,842],"block_position":"8-2"},{"bbox":[24,486,304,503],"type":"text","angle":0,"index":3,"text":"练。 $\\textcircled{1}$ 如何查看码制是否被训练，如下二图：","color":{"line":