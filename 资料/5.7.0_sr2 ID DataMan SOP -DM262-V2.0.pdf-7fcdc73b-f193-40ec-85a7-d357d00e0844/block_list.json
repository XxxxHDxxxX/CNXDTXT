32,428],"type":"title","angle":0,"index":2,"text":"# 4.5.如何选择码制。如下图：","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":10,"id":"52339c39-45f0-42f0-851c-fd44ef8c8c02","page_size":[595,842],"block_position":"10-2"},{"bbox":[88,431,506,756],"index":3,"angle":0,"type":"image","img_path":"/024f91659167a96d961e3a9a310ce0f9812c2076d04a0dade3a4008bfdea8ee9.jpg","color":{"line":"rgba(89, 92, 220, 1)","fill":"rgba(89, 92, 220, 1)"},"img_ratio":0.7025210084033613,"page_idx":10,"id":"a768c8b8-064a-4b52-9160-f640e62f6ce9","page_size":[595,842],"block_position":"10-3"}],[{"bbox":[102,79,392,95],"index":0,"angle":0,"type":"image_caption","text":"点击条码符号助手后会弹出新对话框，如下图：","id":"ec12dbd4-5955-4d4d-a2dc-c7521f43c181","color":{"line":"rgba(13, 83, 222 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":11,"page_size":[595,842],"block_position":"11-0"},{"bbox":[88,106,505,426],"index":1,"angle":0,"type":"image","img_path":"/da61aa319a79346f9f65f323698809b59aa069cf88fb3b7d689ca4b2d2fa2462.jpg","color":{"line":"rgba(89, 92, 220, 1)","fill":"rgba(89, 92, 220, 1)"},"img_ratio":0.7008403361344537,"page_idx":11,"id":"5d305188-1c53-462e-b294-d8146ee82c77","page_size":[595,842],"block_position":"11-1"},{"bbox":[77,431,539,447],"type":"text","angle":0,"index":2,"text":"当前选项码制更改的是当前选择的setup，此选项决定当前setup可以读取哪些类型的码","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":11,"id":"ae685d1d-48be-46e6-890b-e19b03c58c70","page_size":[595,842],"block_position":"11-2"},{"bbox":[75,459,424,475],"type":"text","angle":0,"index":3,"text":"注意：每个setup都有自己的符号助手，可以下拉切换查看和更改","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":11,"id":"57cc5a35-fdca-4c6f-841f-f092293b8424","page_size":[595,842],"block_position":"11-3"},{"bbox":[46,500,540,585],"index":4,"angle":0,"type":"image","img_path":"/ea3e6a85fd51c707c98eb6f119adecacca051bd1d3aaad561ae51e6df4d94bb0.jpg","color":{"line":"rgba(89, 92, 220, 1)","fill":"rgba(89, 92, 220, 1)"},"img_ratio":0.8302521008403362,"page_idx":11,"id":"99b228b6-775a-4b82-8a33-6057e8124447","page_size":[595,842],"block_position":"11-4"}],[{"bbox":[8,12,144,31],"type":"title","angle":0,"index":0,"text":"# 4.6读取多个码设置","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":12,"id":"0511520b-fd8e-4c36-a990-3deedd8baa10","page_size":[595,841],"block_position":"12-0"},{"bbox":[5,33,178,61],"type":"text","angle":0,"index":1,"text":"点击-设置-读码类型图标-多代码","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":12,"id":"cce3c160-0d8d-41eb-94e4-459d0f4d9422","page_size":[595,841],"block_position":"12-1"},{"bbox":[4,70,124,88],"type":"title","angle":0,"index":2,"text":"# 4.6.1.多代码设置","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":12,"id":"fda3ea17-bf67-4f80-b7d8-93f6a5471ecc","page_size":[595,841],"block_position":"12-2"},{"bbox":[4,89,172,113],"type":"text","angle":0,"index":3,"text":"代码数量_-需要读取几个码，如果两个就写2，兰个就写3","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":12,"id":"99ecf125-144e-4df5-9ba5-25607255517b","page_size":[595,841],"block_position":"12-3"},{"bbox":[21,114,119,126],"type":"text","angle":0,"index":4,"text":"允许部分结果输出","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":12,"id":"a73ffa85-680b-4d83-b33d-fcf417c47aff","page_size":[595,841],"block_position":"12-4"},{"bbox":[4,126,179,174],"type":"text","angle":0,"index":5,"text":"如果视野内物料码没有全部解出来，要不要只把解出来的输出，除非用脚本或者OEM程序能通过信隱省岂判断一般不打勾","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":12,"id":"d331c754-f938-4913-80f0-e2b74987a911","page_size":[595,841],"block_position":"12-5"},{"bbox":[12,185,149,202],"type":"title","angle":0,"index":6,"text":"# 4.6.2.物料码制个数","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":12,"id":"cbfcede4-6779-4ae9-b5db-96778b823704","page_size":[595,841],"block_position":"12-6"},{"bbox":[11,203,175,228],"type":"text","angle":0,"index":7,"text":"需要读取的物料码有几种码制，每种码制各多少","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":12,"id":"1f0a7422-0803-41d8-80ba-31a58f8c6722","page_size":[595,841],"block_position":"12-7"},{"bbox":[11,228,170,264],"type":"text","angle":0,"index":8,"text":"如果代码数量为2，且都是DataMatrix，则需要将DataMatrix的代码最天数量改为2","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":12,"id":"c93247d9-c9a2-4a2a-b31f-85fdf5e25a8b","page_size":[595,841],"block_position":"12-8"},{"bbox":[12,264,152,276],"type":"text","angle":0,"index":9,"text":"，下面其它码值数量改为2","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":12,"id":"c49eb9e7-c08f-49f5-acca-ea869685b95e","page_size":[595,841],"block_position":"12-9"},{"bbox":[24,276,115,288],"type":"text","angle":0,"index":10,"text":"如巢代码数量为3","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":12,"id":"70820de1-75a9-4da8-b271-340e14cee69f","page_size":[595,841],"block_position":"12-10"},{"bbox":[12,288,176,349],"type":"text","angle":0,"index":11,"text":"且DataMatrix的数量为2，QR为1，则需要将Data Matrix 的代码最大数量改为2，QR的代码最大数量为1，其它码值数量改","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":12,"id":"02e32da9-0eb7-424d-a763-2c7302a6dd28","page_size":[595,841],"block_position":"12-11"},{"bbox":[17,364,122,382],"type":"title","angle":0,"index":12,"text":"# 4.6.3.输出顺序","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":12,"id":"ee8d7498-7418-4765-a280-1e953627fd9a","page_size":[595,841],"block_position":"12-12"},{"bbox":[22,389,75,402],"type":"text","angle":0,"index":13,"text":".从左到右","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":12,"id":"cc3774da-6764-47d9-b4a2-7cc626714934","page_size":[595,841],"block_position":"12-13"},{"bbox":[16,405,178,467],"type":"text","angle":0,"index":14,"text":"按照读取码的位置按照从左到右排序，当选择此位置然后点击反向可以改为从右到左.从上倒下","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":12,"id":"65dd32c9-0f2c-4ec9-9fdc-7c780000556a","page_size":[595,841],"block_position":"12-14"},{"bbox":[16,468,174,514],"type":"text","angle":0,"index":15,"text":"按照读取码的位置按照从上到下排序，当选择此位置然后点击反向可以改为从下到上","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":12,"id":"fcb29ab4-3cfd-4745-9877-ece29a3c15c0","page_size":[595,841],"block_position":"12-15"},{"bbox":[17,516,51,530],"type":"text","angle":0,"index":16,"text":"注意：","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":12,"id":"f5e09746-f961-4150-a93f-f792ad1bc0f3","page_size":[595,841],"block_position":"12-16"},{"bbox":[20,532,169,561],"type":"text","angle":0,"index":17,"text":"输出顺序要选择然后点击向上置顶","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":12,"id":"3fe7c8d0-1575-4a34-b70b-d20b8f9cda77","page_size":[595,841],"block_position":"12-17"},{"bbox":[6,634,143,653],"type":"title","angle":0,"index":18,"text":"# 4.6.4.多代码分隔符","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":12,"id":"89525796-9f90-47fe-927b-2f381f5e9cc0","page_size":[595,841],"block_position":"12-18"},{"bbox":[6,655,136,685],"type":"text","angle":0,"index":19,"text":"一次读取多个物料之间用什么符号隔开","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":12,"id":"e9bc401b-2f02-4f12-9d36-d37e4959127d","page_size":[595,841],"block_position":"12-19"},{"bbox":[15,687,136,701],"type":"text","angle":0,"index":20,"text":".在数据格式-通用-标准","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":12,"id":"784cfd3a-11bb-41ba-9eb5-d2844f072374","page_size":[595,841],"block_position":"12-20"},{"bbox":[7,703,126,733],"type":"text","angle":0,"index":21,"text":"-输出选项-多代码分隔符选择","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":12,"id":"44c26e4c-1253-4fdd-998f-f39cc177d496","page_s