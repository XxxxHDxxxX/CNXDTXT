2, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":13,"id":"6788b19a-755c-4f63-9314-04a059acb484","page_size":[595,841],"block_position":"13-3"},{"bbox":[32,470,359,485],"type":"text","angle":0,"index":4,"text":"个码，只需将当前设置搜索框拉大，两个码都在一个搜索框内","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":13,"id":"51dc737e-63aa-44bb-8d09-a45b74785c95","page_size":[595,841],"block_position":"13-4"},{"bbox":[21,491,583,832],"index":5,"angle":0,"type":"image","img_path":"/4919ce633619b2c316b5199eb6b3c9f1bfedfd92a06145edf48adb3f5f133b4f.jpg","color":{"line":"rgba(89, 92, 220, 1)","fill":"rgba(89, 92, 220, 1)"},"img_ratio":0.9445378151260504,"page_idx":13,"id":"4fa2c6ef-8cdb-4509-925f-6d4d265918ec","page_size":[595,841],"block_position":"13-5"}],[{"bbox":[13,14,518,47],"type":"title","angle":0,"index":0,"text":"# 4.7.2下图同两个setup读取两个码，即一个通道读取一个二维码，物料左搜索框只框左侧二维码物料右设置搜索框只框右面码，一个设置读取一个码加起来就是两个码","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":14,"id":"821188b4-f593-4c3c-b9b4-a9e6050ba3ef","page_size":[595,841],"block_position":"14-0"},{"bbox":[0,48,578,841],"index":1,"angle":0,"type":"image","img_path":"/eb37414601ec2447f96c51f8bcdca757d21111d93f63c112156c9ba16c95e908.jpg","color":{"line":"rgba(89, 92, 220, 1)","fill":"rgba(89, 92, 220, 1)"},"img_ratio":0.9714285714285714,"page_idx":14,"id":"f1f90b5f-7f35-4876-84eb-d15dc7ab29f2","page_size":[595,841],"block_position":"14-1"}],[{"bbox":[22,7,208,29],"type":"title","angle":0,"index":0,"text":"# 五．软件备份与导入","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":15,"id":"d6538f65-d9a1-4ab7-b44c-17b4a9d05701","page_size":[595,842],"block_position":"15-0"},{"bbox":[102,43,357,60],"type":"title","angle":0,"index":1,"text":"# 1.软件备份，系统 $\\twoheadrightarrow$ 保存配置 $\\twoheadrightarrow$ 备份设备","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":15,"id":"8fc039da-f9b5-4283-a24e-58892b0421d8","page_size":[595,8