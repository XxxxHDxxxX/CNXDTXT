    {
        "type": "text",
        "text": "四．配置的调试",
        "text_level": 1,
        "bbox": [
            82,
            14,
            329,
            40
        ],
        "page_idx": 5
    },
    {
        "type": "text",
        "text": "设置 $\\twoheadrightarrow$ 读取设置 进入配置调试界面，如下图：",
