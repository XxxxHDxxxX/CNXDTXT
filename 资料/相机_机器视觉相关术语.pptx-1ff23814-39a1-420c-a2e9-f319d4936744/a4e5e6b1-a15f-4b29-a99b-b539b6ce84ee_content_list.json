    {
        "type": "text",
        "text": "工业相机 _ 成像器",
        "text_level": 1,
        "bbox": [
            41,
            22,
            400,
            92
        ],
        "page_idx": 11
    },
    {
        "type": "table",
        "img_path": "images/90a5d240627e01d01a88f89aa96871b6c016b22e17568151e85c6cc92e1c176e.jpg",
        "table_caption": [
            "CCD vs CMOS "
        ],
        "table_footnote": [],
        "table_body": "<table><tr><td></td><td>价格</td><td>噪声（图片暗部的不规则杂点）</td><td>耗电量</td><td>图像锐利度</td><td>速度</td><td>发展趋势</td></tr><tr><td>CCD</td><td>高</td><td>低</td><td>高</td><td>高</td><td>一般</td><td>技术较成熟</td></tr><tr><td>CMOS</td><td>低</td><td>较高</td><td>低</td><td>一般</td><td>快</td><td>生产厂家众多，技术不断有突破性进展</td></tr></table>",
        "bbox": [
            77,
            296,
            913,
            824
        ],
        "page_idx": 11
    },
    {
        "type": "header",
        "text": "COGNEX SUPERHEROES 2013 ",
        "bbox": [
            827,
            5,
            998,
            164
        ],
        "page_idx": 11
    },
    {
        "type": "footer",
        "text": "COGNEX ",
        "bbox": [
            804,
