                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Visionpro 软件保存一般 5 种方式："
                    }
                ]
            },
            "bbox": [
                65,
                407,
                324,
                423
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "equation_inline",
                                "content": "\\textcircled{1}"
                            },
                            {
                                "type": "text",
                                "content": "保存 Quickbuild，后缀名.VPP"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "equation_inline",
                                "content": "\\cdot"
                            },
                            {
                                "type": "text",
                                "content": "保存 Cogjob，后缀名.VPP"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "equation_inline",
                                "content": "\\textcircled{3}"
                            },
                            {
                                "type": "text",
                                "content": "保存 ToolBlock，后缀名.VPP"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "equation_inline",
                                "content": "\\textcircled{4}"
                            },
                            {
                                "type": "text",
                                "content": "保存工具，后缀名.VPP"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "equation_inline",
                                "content": "\\textcircled{5}"
                            },
                            {
                                "type": "text",
                                "content": "保存脚本，后缀名.cs"
                            }
                        ]
                    }
                ]
            },
            "bbox": [
