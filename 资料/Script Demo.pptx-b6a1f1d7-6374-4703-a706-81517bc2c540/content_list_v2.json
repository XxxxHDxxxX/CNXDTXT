                    {
                        "type": "text",
                        "content": "脚本示例"
                    }
                ],
                "level": 1
            },
            "bbox": [
                58,
                183,
                159,
                220
            ]
        },
        {
            "type": "algorithm",
            "content": {
                "algorithm_caption": [],
                "algorithm_content": [
                    {
                        "type": "text",
                        "content": "public class CogToolBlockAdvancedScript : CogToolBlockAdvancedScriptBase   \n{ #region Private Member Variables private Cognex.VisionPro.ToolBlock.CogToolBlock mToolBlock; //定义要显示的标签 private CogGraphicLabel mylabel; #endregion /public override bool GroupRun(ref string message, ref CogToolResultConstants result) { // To let the execution stop in this script when a debugger is attached, uncomment the following lines. //if DEBUG // if (System.DiagnosticsDBGger.IsAttached) System.DiagnosticsDBGger.Break(); // #endif mylabel  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "="
                    },
                    {
                        "type": "text",
                        "content": " new CogGraphicLabel(); //获取Caliper工具的的引用 CogCaliperTool mycaliper  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "="
                    },
                    {
                        "type": "text",
                        "content": " mToolBlock.Tools[\"CogCaliperTool11\"] as CogCaliperTool; //caliper运行前，按照要求设置运行参数 mycaliperRUNParams.ContrastThreshold  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "= 15"
                    },
                    {
                        "type": "text",
                        "content": " . mycaliperRUNParams.FilterHalfSizeInPixels  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "= 2"
                    },
                    {
                        "type": "text",
                        "content": " . mycaliperRUNParams.Ege0Position  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "= -500"
                    },
                    {
                        "type": "text",
                        "content": " . mycaliperRUNParams.EdgelPosition  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "= 500"
                    },
                    {
                        "type": "text",
                        "content": " . // Run each tool using the RunTool function foreach(ICogTool tool in mToolBlock.Tools) mToolBlock.CogTool tool, ref message, ref result); //获取结果,坐标x,y和宽度 double  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf{x} ="
                    },
                    {
                        "type": "text",
                        "content": " mycaliper.Results[O].PositionX; double y  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "="
                    },
                    {
                        "type": "text",
                        "content": " mycaliper.Results[O].PositionY; double width  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "="
                    },
                    {
                        "type": "text",
                        "content": " mycaliper.Results[O].PositionX; //根据结果设置标签 mylabel.Color  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "="
                    },
                    {
                        "type": "text",
                        "content": " CogColorConstants.Green; mylabel.SetXYText(x,y, \"Width:\"+width.ToString(\"f3\")); return false; } When the Current Run Record is Created #region When the Last Run Record is Created /xx/ public override void ModifyLastRunRecord(Cognex.VisionPro.ICogRecord lastRecord) { //添加标签 mToolBlock.AddGraphicToRunRecord(mlabel,lastRecord,\"CogPMAlignTooll.InputImage\",\"s\"); } #endregion "
                    }
                ]
            },
