                    }
                ],
                "level": 1
            },
            "bbox": [
                0,
                248,
                101,
                285
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "LineMax 的返回结果"
                    }
                ],
                "level": 1
            },
            "bbox": [
                0,
                420,
                194,
                459
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "• LineMax 支持图像掩膜器，可以利用图像掩膜将图像中的某些区域不纳入计算范围，如右图所示。"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "• LineMax 中的线段拟合算法主要分为随机抽样一致性 (RANSAC, 在保留大多数候选边缘点的情况下进行线段拟合 ) 和穷尽模式 ( 考虑所有的边缘点组合进行边缘拟合 ) ， LineMax 默认使用 RANSAC 算法，一般穷尽模式会非常耗时。"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "• LineMax返回的结果如下图所示，其中最大误差表示为最远的内点相对线段的距离。"
                            }
                        ]
                    }
                ]
            },
            "bbox": [
