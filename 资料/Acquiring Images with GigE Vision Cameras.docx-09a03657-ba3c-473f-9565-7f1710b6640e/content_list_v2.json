                    },
                    {
                        "type": "text",
                        "content": "Riglt edge of ROl acjustedto get even number ofpixels "
                    }
                ]
            },
            "bbox": [
                196,
                93,
                489,
                287
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "十一、Managing GigE Vision Bandwidth Use "
                    }
                ],
                "level": 1
            },
            "bbox": [
                147,
                334,
                472,
                350
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
