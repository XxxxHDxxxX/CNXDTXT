    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "智能像素映射工具是将输入图像(例如DS1000系列传感器中的cogimage16范围图像)的像素值映射到输出图像(例如 CogImage8Grey)的最简单方法。支持的格式和转换如下:"
                    }
                ]
            },
            "bbox": [
                144,
                112,
                848,
                148
            ]
        },
        {
            "type": "table",
            "content": {
                "image_source": {
                    "path": "images/630961e4d692ef64c9c34351bf23ab6dce29d8ddb22651cba7fe20edf9891109.jpg"
                },
                "table_caption": [
                    {
                        "type": "text",
                        "content": "表1:支持转换"
                    }
                ],
                "table_footnote": [],
                "html": "<table><tr><td>From\\To</td><td>CogImage16Range</td><td>CogImage16Grey</td><td>CogImage8Grey</td></tr><tr><td>CogImage16Range</td><td>See the note below</td><td>✓</td><td>✓</td></tr><tr><td>CogImage16Grey</td><td>See the note below</td><td>✓</td><td>✓</td></tr><tr><td>CogImage8Grey</td><td>See the note below</td><td>Not required</td><td>✓</td></tr></table>",
                "table_type": "simple_table",
