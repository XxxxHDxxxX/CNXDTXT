                "table_footnote": [],
                "html": "<table><tr><td>Points</td><td>Relative Input</td><td>Relative Output</td><td>Absolute Input</td><td>Absolute Output</td></tr><tr><td>0</td><td>0</td><td>0</td><td>0</td><td>0</td></tr><tr><td>1</td><td>0.251602</td><td>0</td><td>16489</td><td>0</td></tr><tr><td>2</td><td>0.395493</td><td>1</td><td>25919</td><td>256</td></tr><tr><td>3</td><td>1</td><td>1</td><td>65536</td><td>256</td></tr></table>",
                "table_type": "simple_table",
