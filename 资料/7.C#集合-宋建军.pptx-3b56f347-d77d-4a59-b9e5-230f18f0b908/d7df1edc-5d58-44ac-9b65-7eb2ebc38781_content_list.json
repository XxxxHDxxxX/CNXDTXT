            420,
            308,
            451
        ],
        "page_idx": 7
    },
    {
        "type": "text",
        "text": "只适用于下列情况：",
        "bbox": [
            59,
            479,
            184,
            509
        ],
        "page_idx": 7
    },
    {
        "type": "list",
        "sub_type": "text",
        "list_items": [
            "1. < operand $>$ 的类型是 < type $>$ 类型",
            "2. < operand $>$ 可以隐式转换为 $<$ type $>$ 类型",
            "3. < operand $>$ 可以封箱到 $<$ type $>$ 类型中",
            "4. 如果不能完成转换，返回 null"
        ],
        "bbox": [
            58,
            538,
