            668,
            633,
            682
        ],
        "page_idx": 0
    },
    {
        "type": "text",
        "text": "MaxResults 找到的最大结果数;",
        "bbox": [
            146,
            686,
            403,
            701
        ],
        "page_idx": 0
    },
