                312
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "您还可以选择使用“提取行”字段并输入该字符串中可见的整个字符串。"
                    }
                ]
            },
            "bbox": [
                176,
