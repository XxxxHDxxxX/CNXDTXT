                589
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "在某些情况下，该工具会生成多次尝试对字符串进行分段的操作，如下所示："
                    }
                ]
            },
            "bbox": [
                191,
                599,
                751,
                615
            ]
        },
        {
            "type": "image",
            "content": {
