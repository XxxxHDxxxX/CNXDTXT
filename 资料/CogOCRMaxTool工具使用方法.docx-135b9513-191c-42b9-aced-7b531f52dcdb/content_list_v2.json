                335
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "9. 单击添加和调整将这些新字符添加到当前字体。"
                    }
                ]
            },
            "bbox": [
                152,
