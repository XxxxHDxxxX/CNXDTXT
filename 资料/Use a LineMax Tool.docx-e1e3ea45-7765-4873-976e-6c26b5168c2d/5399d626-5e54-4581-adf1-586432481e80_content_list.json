    },
    {
        "type": "text",
        "text": "Change mask offset and size ",
        "bbox": [
            218,
            344,
            423,
            360
        ],
        "page_idx": 8
    },
    {
        "type": "text",
        "text": "使用以下对话框修改遮罩图像的偏移量和大小:",
        "bbox": [
            216,
