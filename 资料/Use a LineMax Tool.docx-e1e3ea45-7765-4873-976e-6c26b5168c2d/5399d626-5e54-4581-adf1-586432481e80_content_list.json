    },
    {
        "type": "text",
        "text": "Control Buttons ",
        "text_level": 1,
        "bbox": [
            146,
            501,
            263,
            514
        ],
        "page_idx": 7
    },
    {
        "type": "text",
        "text": "图像掩模编辑器支持以下按钮栏沿顶部的编辑器:",
        "bbox": [
            181,
            519,
            563,
            533
        ],
        "page_idx": 7
    },
    {
        "type": "image",
        "img_path": "images/6b0c30ef566344b93cedf7406e78476548d3077ca765cbaac76576a9cc7091ff.jpg",
        "image_caption": [],
