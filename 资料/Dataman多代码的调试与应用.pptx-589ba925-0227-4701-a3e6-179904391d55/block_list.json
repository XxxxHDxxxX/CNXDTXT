a(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":1,"id":"bf586978-831b-4890-a6c1-1d8ac2f0181b","page_size":[959,540],"block_position":"1-2"},{"bbox":[60,149,479,173],"type":"text","angle":0,"index":3,"text":"1. 两个码的调试应用，以 RS-OVEN1 项目为例","id":"08782010-0a9f-4d6f-bdda-341294744004","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":1,"page_size":[959,540],"block_position":"1-3"},{"bbox":[60,180,536,205],"type":"text","angle":0,"index":4,"text":"2. 两个码以上的调试应用，以 ANDA-PAMD 项目为例","id":"5efacb11-c54f-4324-9cca-e0224b8c605a","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":1,"page_size":[959,540],"block_position":"1-4"},{"bbox":[52,521,181,534],"type":"footer","angle":0,"index":1000006,"text":"$\\circledcirc$ 2020 Cognex Confidential","color":{"line":"rgba(164, 164, 164, 1)","fill":"rgba(164, 164, 164, 1)"},"page_idx":1,"is_discarded":true,"id":"8c78f859-413c-41a6-9bc8-92ffb5b72c01","page_size":[959,540],"block_position":"1-5"},{"bbox":[820,515,939,533],"type":"footer","angle":0,"index":1000007,"text":"COGNEX","color":{"line":"rgba(164, 164, 164, 1)","fill":"rgba(164, 164, 164, 1)"},"page_idx":1,"is_discarded":true,"id":"2bacaf3d-c50e-4217-a5cc-1eb6bbe5e661","page_size":[959,540],"block_position":"1-6"}],[{"bbox":[61,25,352,61],"type":"title","angle":0,"index":0,"text":"# 多代码的调试与应用","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":2,"id":"74ffb1e6-db81-497b-87fd-9e2154b93bf9","page_size":[959,540],"block_position":"2-0"},{"bbox":[77,77,300,106],"type":"title","angle":0,"index":1,"text":"# 1. 两个码的调试应用","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":2,"id":"7710a25b-1b22-4679-af45-77ee25462470","page_size":[959,540],"block_position":"2-1"},{"bbox":[81,133,823,223],"type":"text","angle":0,"index":2,"text":"RS-OVEN1 设备使用的扫码枪型号是 DM262X-1540P, 需要同时扫载具码和盖板码 ,而 DATAMAN 软件的默认设置是输出一个条码，所以就要在 DATAMAN 软件里重新设置了，下面就讲讲 DATAMAN 软件里两个码与一个码设置的区别之处。","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":2,"id":"1646803d-eb1b-4a72-9897-b477be628313","page_size":[959,540],"block_position":"2-2"},{"bbox":[52,521,181,533],"type":"footer","angle":0,"index":1000003,"text":"$\\circledcirc$ 2020 Cognex Confidential","color":{"line":"rgba(164, 164, 164, 1)","fill":"rgba(164, 164, 164, 1)"},"page_idx":2,"is_discarded":true,"id":"08016046-08ba-4c53-877d-9ff658419185","page_size":[959,540],"block_position":"2-3"},{"bbox":[820,515,939,533],"type":"footer","angle":0,"index":1000004,"text":"COGNEX","color":{"line":"rgba(164, 164, 164, 1)","fill":"rgba(164, 164, 164, 1)"},"page_idx":2,"is_discarded":true,"id":"9ffb4276-b446-4956-9db2-e941d9f7513c","page_size":[959,540],"block_position":"2-4"}],[{"bbox":[63,25,351,60],"type":"title","angle":0,"index":0,"text":"# 多代码的调试与应用","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":3,"id":"4fb69823-6036-4d78-a291-9768140942fa","page_size":[959,540],"block_position":"3-0"},{"bbox":[77,66,300,92],"type":"title","angle":0,"index":1,"text":"# 1. 两个码的调试应用","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":3,"id":"19320eae-7a3d-41e6-83bc-95b0fa83fcbe","page_size":[959,540],"block_position":"3-1"},{"bbox":[80,102,368,471],"index":2,"angle":0,"type":"image","img_path":"/77896803d0434171b498867b09eaf242483dcd7a6531a8baec3415524da49089.jpg","color":{"line":"rgba(89, 92, 220, 1)","fill":"rgba(89, 92, 220, 1)"},"img_ratio":0.30031282586027114,"page_idx":3,"id":"849dfe05-b1f1-4575-b2ce-2432cd37a8e1","page_size":[959,540],"block_position":"3-2"},{"bbox":[441,160,565,184],"type":"title","angle":0,"index":3,"text":"# 代码数量设置","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":3,"id":"2a31e453-9de0-49f8-baca-32949c11aa08","page_size":[959,540],"block_position":"3-3"},{"bbox":[441,192,734,281],"type":"text","angle":0,"index":4,"text":"在读码类型里找到多代码设置，代码数量设为 2 ，如果两个码都是 Data Matrix 码，代码的最大数量也设为2","id":"e81a4690-a644-48e0-abab-b72e6bd5fd5e","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":3,"page_size":[959,540],"block_position":"3-4"},{"bbox":[441,288,735,376],"type":"text","angle":0,"index":5,"text":"另允许部分结果输出意思是不勾选代表只有扫到两个码时才输出，勾选代表扫到一个码或两个码时都能输出。","id":"7ee88ce7-047c-4c1e-821e-175ceeff5f55","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"page_idx":3,"page_size":[959,540],"block_position":"3-5"},{"bbox":[52,521,180,533],"type":"footer","angle":0,"index":1000007,"text":"$\\circledcirc$ 2020 Cognex Confidential","color":{"line":"rgba(164, 164, 164, 1)","fill":"rgba(164, 164, 164, 1)"},"page_idx":3,"is_discarded":true,"id":"aa8cfbfc-eb46-4ced-8a1e-418032420bb6","page_size":[959,540],"block_position":"3-6"},{"bbox":[821,515,939,533],"type":"footer","angle":0,"index":1000008,"text":"COGNEX","color":{"line":"rgba(164, 164, 164, 1)","fill":"rgba(164, 164, 164, 1)"},"page_idx":3,"is_discarded":true,"id":"ba88d4aa-4f07-4f1f-a767-66ad7e91a9a9","page_size":[959,540],"block_position":"3-7"}],[{"bbox":[63,25,351,60],"type":"title","angle":0,"index":0,"text":"# 多代码的调试与应用","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":4,"id":"365db94b-392c-4080-a7a0-873a058747c4","page_size":[959,540],"block_position":"4-0"},{"bbox":[77,66,300,92],"type":"title","angle":0,"index":1,"text":"# 1. 两个码的调试应用","color":{"line":"rgba(13, 83, 222, 1)","fill":"rgba(13, 83, 222, 1)"},"level":1,"page_idx":4,"id":"3aee2f42-4cdc-4925-a09b-a7b5f232c4d2","page_size":[959,540],"block_position":"4-1"},{"bbox":[75,127,428,219],"index":2,"angle":0,"type":"image","img_path":"/56c3f50aaa1cb68f346c984fb1dffd7373ae2609b9dcf93307e407010caa509b.jpg","color":{"line":"rgba(89, 92, 220, 1)","fill":"rgba(89, 92, 220, 1)"},"img_ratio":0.3680917622523462,"page_idx":4,"id":"86c3dcb8-45c9-4dfe-94d6-9222336394b3","page_size":[959,540],"block_position":"4-2"},{"bbox":[71,243,4